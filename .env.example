# ============================================================
# Lagos Rhythm Virtual Tour — Backend Environment Variables
# ============================================================

# ---- Firebase Backend (Admin SDK) --------------------------
# Option 1: Set FIREBASE_SERVICE_ACCOUNT_KEY with the JSON content
# Option 2: Place the service account JSON file in the project root
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ---- Firebase Frontend (Admin Login UI) --------------------
# Your Firebase project Web API Key.
# VITE_FIREBASE_API_KEY=AIzaSy...

# ---- Server ------------------------------------------------
PORT=3001
NODE_ENV=production

# ---- Admin Passcode ----------------------------------------
VITE_ADMIN_PASSCODE=your_passcode_here

# ---- Live Tour Fallback ------------------------------------
# Used only when Firestore is unavailable.
LIVE_TOUR_ACTIVE=false
LIVE_TOUR_TITLE=Lagos Rhythm Live
LIVE_TOUR_DESCRIPTION=A live virtual tour of Lagos is currently broadcasting.
LIVE_TOUR_HOST=Lagos Rhythm
LIVE_TOUR_LOCATION=Lagos, Nigeria
LIVE_TOUR_VIEWERS=1245
LIVE_TOUR_STREAM_IMAGE=
LIVE_TOUR_HOST_IMAGE=

# ---- WebSocket ---------------------------------------------
# In production (same-origin), leave blank to use ws://<host>/api/live.
# VITE_TOUR_STATUS_WS_URL=
